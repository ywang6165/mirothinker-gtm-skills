{
  "client_name": "goose",
  "tam_config_name": "yc-series-a-sf",

  "company_filters": {
    "organization_num_employees_ranges": ["1,100"],
    "q_organization_keyword_tags": ["Y Combinator"],
    "organization_locations": ["San Francisco, California"]
  },

  "scoring": {
    "weights": {
      "employee_count_fit": 30,
      "industry_fit": 25,
      "funding_stage_fit": 20,
      "geo_fit": 15,
      "keyword_match": 10
    },
    "tier_thresholds": {
      "tier_1_min_score": 75,
      "tier_2_min_score": 50
    },
    "target_industries": ["Software", "Information Technology", "SaaS", "Artificial Intelligence", "FinTech", "Computer Software"],
    "target_employee_ranges": [[1, 100]],
    "target_funding_stages": ["Series A"],
    "target_geos": ["United States", "San Francisco"]
  },

  "watchlist": {
    "enabled": true,
    "personas_per_company": 3,
    "person_filters": {
      "person_titles": ["Head of Growth", "VP of Marketing", "Head of Sales", "CRO", "CMO", "VP of Sales"],
      "person_seniority": ["vp", "director", "c_suite", "founder"]
    },
    "tiers_to_watch": [1, 2]
  },

  "mode": "standard",
  "max_pages": 50
}
