{
  "client_name": "hb-gtm-agency",
  "tam_config_name": "b2b-tech-gtm-leaders",

  "company_filters": {
    "organization_num_employees_ranges": ["51,200", "201,500"],
    "q_organization_keyword_tags": ["SaaS", "software", "artificial intelligence", "cybersecurity", "fintech", "developer tools", "data analytics", "healthtech", "health tech", "automation"],
    "organization_locations": ["United States"],
    "organization_not_industries": ["Non-Profit Organization Management", "Government Administration", "Education", "Staffing and Recruiting", "Management Consulting", "Marketing and Advertising", "Public Relations and Communications"]
  },

  "scoring": {
    "weights": {
      "employee_count_fit": 25,
      "industry_fit": 20,
      "funding_stage_fit": 15,
      "geo_fit": 15,
      "keyword_match": 10,
      "company_type_fit": 15
    },
    "tier_thresholds": {
      "tier_1_min_score": 75,
      "tier_2_min_score": 50
    },
    "target_industries": ["Software", "Information Technology", "Computer Software", "Artificial Intelligence", "Financial Technology", "Computer & Network Security", "Internet", "Health Care Information Technology"],
    "target_employee_ranges": [[51, 200], [201, 500]],
    "target_funding_stages": ["Series A", "Series B", "Series C"],
    "target_geos": ["United States"]
  },

  "watchlist": {
    "enabled": true,
    "personas_per_company": 3,
    "person_filters": {
      "person_titles": ["CEO", "Founder", "Co-founder", "VP of Marketing", "VP of Sales", "Head of Growth", "Head of Marketing", "Head of Sales", "Head of GTM", "CRO", "CMO"],
      "person_seniority": ["founder", "c_suite", "vp", "director"]
    },
    "tiers_to_watch": [1, 2]
  },

  "mode": "standard",
  "max_pages": 3
}
