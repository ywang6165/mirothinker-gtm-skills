{
  "client_name": "example-client",
  "signals": {
    "headcount_growth": {
      "enabled": true,
      "threshold_pct": 10,
      "lookback_days": 90
    },
    "tech_stack_change": {
      "enabled": true
    },
    "funding_round": {
      "enabled": true
    },
    "job_postings": {
      "enabled": true,
      "keywords": ["devops", "platform engineer", "CI/CD"],
      "max_jobs_per_company": 50,
      "posted_limit": "week"
    },
    "linkedin_content": {
      "enabled": true,
      "problem_description": "Slow CI/CD pipelines, long build times, developer productivity",
      "relevance_threshold": 6,
      "max_posts": 10,
      "llm_analysis": true
    },
    "profile_changes": {
      "enabled": true,
      "detect_job_change": true,
      "detect_title_change": true,
      "detect_company_change": true
    }
  },
  "apify_token_env": "APIFY_TOKEN",
  "anthropic_key_env": "ANTHROPIC_API_KEY",
  "scan_scope": {
    "company_tiers": [1, 2],
    "tam_status": "active",
    "person_lead_statuses": ["monitoring", "signal_detected", "qualified"]
  }
}
