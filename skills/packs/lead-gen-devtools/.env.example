# Apify (required for Reddit, LinkedIn Jobs, Google Jobs, Meetup, Luma scrapers)
# Get your token at https://console.apify.com/account/integrations
APIFY_API_TOKEN=your_apify_api_token_here

# Product Hunt (optional, for competitor-signals PH API access)
# Get at https://api.producthunt.com/v2/oauth/applications
PRODUCTHUNT_TOKEN=your_producthunt_token_here

# ListenNotes (optional, for podcast search in event-signals)
# Free tier: 300 req/month — https://www.listennotes.com/api/
LISTENNOTES_API_KEY=your_listennotes_api_key_here
